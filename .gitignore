# Ignore everything at the repo root, then whitelist only the project folders
/*
!/.gitignore
!/README.md
!/contract/
!/frontend/
!/docs/
!/Roman/

# Inside Roman/ — ignore everything except claude/
Roman/*
!Roman/claude/

# Ignore generated / private artefacts
contract/node_modules/
contract/build/
contract/.env
contract/derive-wallet.cjs
contract/wallet-gen.mjs
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.vite/
Roman/claude/contract/node_modules/
Roman/claude/contract/build/
Roman/claude/contract/.env
Roman/claude/frontend/node_modules/
Roman/claude/frontend/dist/
Roman/claude/frontend/.env
Roman/claude/frontend/.vite/
