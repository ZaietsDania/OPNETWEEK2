# Ignore everything at the repo root, then whitelist only the project folders
/*
!/.gitignore
!/README.md
!/contract/
!/frontend/
!/docs/

# Ignore generated / private artefacts
contract/node_modules/
contract/build/
contract/.env
contract/derive-wallet.cjs
contract/wallet-gen.mjs
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.vite/
