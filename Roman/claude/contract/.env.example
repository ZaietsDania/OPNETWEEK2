# ── Wallet ─────────────────────────────────────────────────────────────────────
# Bitcoin WIF private key  (run `node wallet-gen.mjs` to generate a fresh one)
WALLET_WIF=

# MLDSA quantum-resistant private key in base58 (generated alongside WIF above)
MLDSA_PRIVATE_KEY=

# ── Network ─────────────────────────────────────────────────────────────────────
# regtest | testnet | mainnet
NETWORK=regtest

# OP_NET node RPC base URL
# Regtest:  https://regtest.opnet.org
# Testnet:  https://testnet.opnet.org
# Mainnet:  https://api.opnet.org
RPC_URL=https://regtest.opnet.org

# ── Fees ─────────────────────────────────────────────────────────────────────────
# Priority fee in satoshis added on top of the base fee (default: 10000)
PRIORITY_FEE=10000
